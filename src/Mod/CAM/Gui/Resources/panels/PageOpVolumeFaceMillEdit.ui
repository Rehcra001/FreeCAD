            <string>Allowance</string>
           </property>
          </widget>
         </item>
         <item row="0" column="1">
          <widget class="Gui::QuantitySpinBox" name="featureAllowanceLinked">
           <property name="toolTip">
            <string>Material to leave on protected model and selected keepout geometry in both the job/world XY plane and the job/world +Z axis while linked mode is active. Separate X and Y values are not supported in this phase.</string>
           </property>
          </widget>
         </item>
        </layout>
       </widget>
      </item>
      <item row="2" column="0" colspan="2">
