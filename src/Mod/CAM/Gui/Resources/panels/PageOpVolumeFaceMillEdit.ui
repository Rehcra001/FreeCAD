      </item>
      <item row="0" column="1">
       <widget class="QComboBox" name="featureAllowanceMode">
        <property name="toolTip">
         <string>Linked edits one value for both XY and Z feature allowance. Independent edits XY and Z separately. Allowance directions use job/world axes, and separate X and Y values are not supported in this phase. Operation placement or workplane rotation does not rotate these allowance directions.</string>
        </property>
       </widget>
      </item>
      <item row="1" column="0" colspan="2">
       <widget class="QFrame" name="featureAllowanceLinkedFrame">
        <layout class="QFormLayout" name="formLayout_2">
