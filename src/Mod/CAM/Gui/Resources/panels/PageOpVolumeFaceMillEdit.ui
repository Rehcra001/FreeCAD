     </property>
     <property name="frameShadow">
      <enum>QFrame::Raised</enum>
     </property>
     <layout class="QGridLayout" name="gridLayout_2">
      <item row="0" column="0">
       <widget class="QLabel" name="optimizationMode_label">
        <property name="text">
         <string>Optimization mode</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QComboBox" name="optimizationMode">
        <property name="toolTip">
         <string>Select optional travel-reduction behavior. Volume Face Mill is stock/world-Z oriented; operation placement or workplane rotation does not rotate the stock-derived machining volume.</string>
        </property>
       </widget>
      </item>
      <item row="1" column="0" colspan="2">
       <widget class="QCheckBox" name="protectSelectedFeatures">
         <property name="toolTip">
          <string>Protect selected non-target geometry as additional keepout. The lowest selected horizontal face sets the final depth. Selected geometry does not redefine the stock boundary. Target detection uses Job/world Z.</string>
         </property>
        <property name="text">
         <string>Protect selected geometry</string>
        </property>
       </widget>
      </item>
      <item row="2" column="0" colspan="2">
       <widget class="QCheckBox" name="clearEdges">
         <property name="toolTip">
          <string>Volume Face Mill uses the Job stock extents as its machining boundary in Job/world XY. Allow the tool center to overhang those stock exterior edges so they can be fully cleared.</string>
         </property>
        <property name="text">
         <string>Clear stock edges</string>
        </property>
       </widget>
      </item>
      <item row="3" column="0" colspan="2">
       <widget class="QCheckBox" name="useStartPoint">
        <property name="toolTip">
         <string>Specify if this operation uses a starting point.</string>
        </property>
        <property name="text">
         <string>Use start point</string>
        </property>
       </widget>
      </item>
      <item row="3" column="2">
       <widget class="QToolButton" name="setStartPoint">
